# Telegram Bot Token (obtained from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration (Uncomment/configure based on your model choice)
# For local model setup (Ollama is recommended):
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b

# If using a cloud provider like OpenAI instead of Ollama:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=your_openai_api_key_here
