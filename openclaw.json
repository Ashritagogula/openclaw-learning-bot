{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "${env.OLLAMA_BASE_URL}",
        "api": "ollama",
        "models": [
          {
            "id": "llama3:8b",
            "name": "Llama 3 (8B)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "ollama/llama3:8b"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${env.TELEGRAM_BOT_TOKEN}"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./skills"
      ]
    }
  }
}
